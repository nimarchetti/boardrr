# Output mode: "zmq" (ZMQ frame push, Pi 5 + Switchrr) or "spi" (direct SPI OLED)
OUTPUT_MODE=zmq

# Required when OUTPUT_MODE=zmq
SWITCHRR_FRAME_ADDRESS=tcp://localhost:5600
SWITCHRR_EVENT_ADDRESS=tcp://localhost:5557
MODE_NAME=uk_tdd

# Display dimensions (used in both modes)
DISPLAY_WIDTH=256
DISPLAY_HEIGHT=64

# SPI mode notes:
# - Install requirements-spi.txt into your venv:
#     .venv/bin/pip install -r requirements-spi.txt
# - run.sh passes the necessary luma CLI args automatically when OUTPUT_MODE=spi
# - For the pygame emulator: pip install luma.emulator, then run:
#     OUTPUT_MODE=spi .venv/bin/python3 src/main.py --display pygame --width 256 --height 64
